# Database (Railway PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/leadpulse?schema=public"

# App URL (set automatically on Vercel, override for local dev)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: Google Places API key for Google Maps scraper
# GOOGLE_PLACES_API_KEY=""

# Optional: ScrapingBee API key (legacy, not used in Phase 1 scrapers)
# SCRAPINGBEE_API_KEY=""

# Vercel Cron secret (set this in Vercel env vars)
CRON_SECRET="generate-a-random-secret-here"
